@{
    var conceptNumber = ViewData["ConceptNumber"]?.ToString() ?? "1";
    var reelId = $"ispPhotoReel{conceptNumber}";
}
<section class="photo-reel" aria-labelledby="reel-title-@conceptNumber">
    <div class="photo-reel__heading">
        <p>Illinois State Police</p>
        <h1 id="reel-title-@conceptNumber">Serving every community.</h1>
    </div>

    <div id="@reelId"
         class="carousel slide carousel-fade"
         data-bs-ride="carousel"
         data-bs-interval="6500"
         data-bs-touch="true"
         aria-roledescription="carousel"
         aria-label="Illinois State Police photo reel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/img/ISP Headquarters Fall.jpg"
                     alt="Illinois State Police headquarters framed by autumn trees" />
            </div>
            <div class="carousel-item">
                <img src="~/img/Plane_K9_100th_squad.jpg"
                     alt="Illinois State Police personnel, aircraft, and K-9 unit" />
            </div>
            <div class="carousel-item">
                <img src="~/img/Command Staff Chicago.jpg"
                     alt="Illinois State Police command staff gathered in Chicago" />
            </div>
            <div class="carousel-item">
                <img src="~/img/DSC_5012A.jpg"
                     alt="Illinois State Police serving communities across Illinois" />
            </div>
        </div>

        <div class="photo-reel__controls">
            <button type="button" data-bs-target="#@reelId" data-bs-slide="prev">
                <span aria-hidden="true">←</span><span class="visually-hidden">Previous photo</span>
            </button>
            <button class="reel-toggle" type="button" data-reel-toggle data-reel-id="@reelId" aria-pressed="false">
                Pause
            </button>
            <span class="photo-reel__count" aria-hidden="true">01 / 04</span>
            <button type="button" data-bs-target="#@reelId" data-bs-slide="next">
                <span aria-hidden="true">→</span><span class="visually-hidden">Next photo</span>
            </button>
        </div>
    </div>
</section>
