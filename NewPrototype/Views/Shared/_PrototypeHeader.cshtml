@{
    var conceptNumber = ViewData["ConceptNumber"]?.ToString() ?? "1";
}
<header class="prototype-header">
    <div class="prototype-header__bar">
        <a class="prototype-brand"
           asp-controller="Home"
           asp-action="Index"
           a11y-label="Illinois State Police demo homepage"
           a11y-hit-target="@A11yTargetSize.Enhanced">
            <img src="~/img/ISP_Department Seal (Scaled).png"
                 width="78"
                 height="78"
                 alt="" />
            <span>
                <strong>Illinois State Police</strong>
                <small>Integrity · Service · Pride</small>
            </span>
        </a>

        <button class="prototype-menu"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#prototypeNavigation"
                aria-controls="prototypeNavigation"
                aria-expanded="false"
                aria-label="Open navigation">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </button>

        <nav class="prototype-nav collapse" id="prototypeNavigation" aria-label="Primary navigation and site search">
            <div class="prototype-nav__links">
                <a href="#service-categories">Services</a>
                <a href="#about-menu">About ISP</a>
                <a href="/news">News</a>
                <a href="#agency-footer">Contact</a>
            </div>

            <form class="prototype-search"
                  action="https://www.google.com/search"
                  method="get"
                  role="search">
                <input type="hidden" name="sitesearch" value="isp.illinois.gov" />
                <label class="visually-hidden" for="prototype-search-input">Search the Illinois State Police website</label>
                <div class="prototype-search__field">
                    <span class="prototype-search__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="22" height="22" focusable="false">
                            <circle cx="11" cy="11" r="6.5"></circle>
                            <path d="m16 16 4.25 4.25"></path>
                        </svg>
                    </span>
                    <input id="prototype-search-input"
                           name="q"
                           type="search"
                           placeholder="How can we help you?"
                           autocomplete="off" />
                    <span class="prototype-search__provider" aria-label="Enhanced by Google">Enhanced by <strong>Google</strong></span>
                    <button type="submit">Search</button>
                </div>
            </form>
        </nav>
    </div>

    <nav class="concept-switcher" aria-label="Homepage concept selector">
        <span>Viewing concept @conceptNumber</span>
        <a asp-controller="Home" asp-action="Index" aria-current="@(conceptNumber == "1" ? "page" : null)">1</a>
        <a asp-controller="Home" asp-action="Index2" aria-current="@(conceptNumber == "2" ? "page" : null)">2</a>
        <a asp-controller="Home" asp-action="Index3" aria-current="@(conceptNumber == "3" ? "page" : null)">3</a>
        <a asp-controller="Home" asp-action="Index4" aria-current="@(conceptNumber == "4" ? "page" : null)">4</a>
    </nav>
</header>
